<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

  <persistence-unit name="persistencePU" transaction-type="RESOURCE_LOCAL">
    <class>mx.SauapELS.entity.Usuario</class>
    <class>mx.SauapELS.entity.Profesor</class>
    <class>mx.SauapELS.entity.UnidadAprendizaje</class>
    <class>mx.SauapELS.entity.Asignacion</class>

    <properties>
